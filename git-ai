#!/bin/bash

# Usage: git ai commit [model] [--edit|-e]
# model: claude (default), copilot, codex
# --edit / -e : open editor (vi) after generating commit message

COMMAND=$1
shift

if [ "$COMMAND" != "commit" ]; then
  echo "Usage: git ai commit [claude|copilot|codex] [--edit|-e]"
  exit 1
fi

MODEL=""
EDIT_MODE=false

for arg in "$@"; do
  case "$arg" in
    --edit|-e)
      EDIT_MODE=true
      ;;
    claude|copilot|codex)
      MODEL="$arg"
      ;;
    *)
      echo "Unknown option: $arg"
      echo "Usage: git ai commit [claude|copilot|codex] [--edit|-e]"
      exit 1
      ;;
  esac
done

# --- Spinner ---
spinner() {
  local pid=$1
  local model=$2
  local frames=('‚†č' '‚†ô' '‚†Ļ' '‚†ł' '‚†ľ' '‚†ī' '‚†¶' '‚†ß' '‚†á' '‚†Ź')
  local i=0
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r  ${frames[$i]} Generating commit message with %s..." "$model"
    i=$(( (i + 1) % ${#frames[@]} ))
    sleep 0.1
  done
  printf "\r%-60s\r" " "
}

# --- Try a model and return its output ---
try_model() {
  local m=$1
  local output
  case $m in
    claude)
      if ! command -v claude &>/dev/null; then return 1; fi
      output=$(claude -p "$DIFF $PROMPT" 2>/dev/null)
      ;;
    copilot)
      if ! command -v copilot &>/dev/null; then return 1; fi
      output=$(copilot -p "$DIFF $PROMPT" 2>/dev/null)
      ;;
    codex)
      if ! command -v codex &>/dev/null; then return 1; fi
      output=$(codex exec "echo '$DIFF' | cat $PROMPT" 2>/dev/null)
      ;;
    *)
      return 1;
      ;;
  esac
  if [ -z "$output" ]; then return 1; fi
  echo "$output"
  return 0
}

# --- Check staged diff ---
DIFF=$(git diff --staged)
if [ -z "$DIFF" ]; then
  echo "Error: No changes staged. Use 'git add' first."
  exit 1
fi

PROMPT="Generate ONE concise Conventional Commit message (feat:, fix:, refactor:, docs:, chore:). Output only the message. No quotes. No markdown."

# --- Determine model order (specified model goes first) ---
if [ -n "$MODEL" ]; then
  case $MODEL in
    claude)  ORDER=(claude copilot codex) ;; 
    copilot) ORDER=(copilot claude codex) ;; 
    codex)   ORDER=(codex claude copilot) ;; 
  esac
else
  ORDER=(claude copilot codex)
fi

MSG=""
USED_MODEL=""

for m in "${ORDER[@]}"; do
  if ! command -v "$m" &>/dev/null; then
    echo "  ‚ö†ÔłŹ  $m not found, skipping..."
    continue
  fi

  # Run model in background for spinner
  tmp=$(mktemp)
  ( try_model "$m" > "$tmp" 2>&1 ) &
  bg_pid=$!
  spinner $bg_pid "$m"
  wait $bg_pid
  exit_code=$?

  if [ $exit_code -eq 0 ] && [ -s "$tmp" ]; then
    MSG=$(cat "$tmp")
    USED_MODEL="$m"
    rm -f "$tmp"
    break
  else
    echo "  ‚úó $m failed or returned empty, trying next..."
    rm -f "$tmp"
  fi
done

if [ -z "$MSG" ]; then
  echo "Error: All models failed. Please check your AI CLI tools."
  exit 1
fi

echo "‚úÖ Generated by $USED_MODEL"
echo "---"
echo "Proposed: $MSG"
echo "---"

if [ "$EDIT_MODE" = true ]; then
  git commit -m "$MSG" -e
else
  git commit -m "$MSG"
fi
