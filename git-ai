#!/bin/bash

# Usage: git ai commit [model] [--edit|-e]
# model: claude (default), copilot, codex
# --edit / -e : open editor (vi) after generating commit message

COMMAND=$1
shift

if [ "$COMMAND" != "commit" ]; then
  echo "Usage: git ai commit [claude|copilot|codex] [--edit|-e]"
  exit 1
fi

MODEL=""
EDIT_MODE=false

for arg in "$@"; do
  case "$arg" in
    --edit|-e)
      EDIT_MODE=true
      ;;
    claude|copilot|codex)
      MODEL="$arg"
      ;;
    *)
      echo "Unknown option: $arg"
      echo "Usage: git ai commit [claude|copilot|codex] [--edit|-e]"
      exit 1
      ;;
  esac
done

# --- Spinner ---
spinner() {
  local pid=$1
  local model=$2
  local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  local i=0
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r  ${frames[$i]} Generating commit message with %s..." "$model"
    i=$(( (i + 1) % ${#frames[@]} ))
    sleep 0.1
  done
  printf "\r%-60s\r" " "
}

# --- Try a model and return its output ---
try_model() {
  local m=$1
  local output
  case $m in
    claude)
      if ! command -v claude &>/dev/null; then return 1; fi
      output=$(echo "$DIFF" | claude -p "$PROMPT" 2>/dev/null)
      ;;
    copilot)
      if ! command -v copilot &>/dev/null; then return 1; fi
      output=$(echo "$DIFF" | copilot -p "$PROMPT" 2>/dev/null)
      ;;
    codex)
      if ! command -v codex &>/dev/null; then return 1; fi
      output=$(echo "$DIFF" | codex exec "$PROMPT" 2>/dev/null)
      ;;
    *)
      return 1;
      ;;
  esac
  if [ -z "$output" ]; then return 1; fi
  echo "$output"
  return 0
}

# --- Check staged diff ---
DIFF=$(git diff --staged)
if [ -z "$DIFF" ]; then
  echo "Error: No changes staged. Use 'git add' first."
  exit 1
fi

PROMPT="Generate ONE concise Conventional Commit message (feat:, fix:, refactor:, docs:, chore:). Output only the message. No quotes. No markdown."

# --- Determine model order (specified model goes first) ---
if [ -n "$MODEL" ]; then
  case $MODEL in
    claude)  ORDER=(claude copilot codex) ;; 
    copilot) ORDER=(copilot claude codex) ;; 
    codex)   ORDER=(codex claude copilot) ;; 
  esac
else
  ORDER=(claude copilot codex)
fi

MSG=""
USED_MODEL=""